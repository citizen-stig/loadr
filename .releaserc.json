{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    ["@semantic-release/github", {
      "assets": [
        { "path": "dist/*.tar.gz" },
        { "path": "dist/*.tar.gz.sha256" },
        { "path": "dist/*.zip" },
        { "path": "dist/*.zip.sha256" },
        { "path": "dist/SHA256SUMS" }
      ]
    }]
  ]
}
